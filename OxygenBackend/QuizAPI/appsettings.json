{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "https://localhost:8000",
    "Audience": "https://localhost:5173"
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:5173", "http://localhost:5173" ]
  },
  "Signup": {
    // When true, signup requires a valid single-use invite code (see docs/invite-code-system-plan.md).
    // Off by default so local dev / open launch needs no code; the test deployment sets
    // Signup__RequireInviteCode=true.
    "RequireInviteCode": false
  }
}
