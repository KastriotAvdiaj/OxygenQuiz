{
  // ---------------------------------------------------------------------------
  // REFERENCE ONLY — this file is NOT loaded by the app. It documents every
  // secret/connection value that must be supplied OUTSIDE source control:
  //   • Development: `dotnet user-secrets set "<key>" "<value>"` (see README)
  //   • Production:  environment variables (use "__" to nest, e.g. Jwt__Key)
  //
  // appsettings.json holds only non-secret config. If any value below is
  // missing at startup the app fails fast (by design) rather than using a
  // hardcoded fallback.
  // ---------------------------------------------------------------------------
  "ConnectionStrings": {
    "PostgresConnection": "Host=<host>;Port=5432;Database=OxygenQuiz;Username=<user>;Password=<password>"
    // MongoDB is disabled (multiplayer chat is ephemeral). When the persistent chat system
    // lands, re-add the connection string below and the "MongoDB:DatabaseName" setting.
    // See docs/data/mongodb.md.
    // "MongoDBConnection": "mongodb://<user>:<password>@<host>:27017"
  },
  "Jwt": {
    // Symmetric signing key. MUST be >= 32 bytes and unique per environment.
    // Generate one with: openssl rand -base64 48
    "Key": "<random-base64-secret-at-least-32-bytes>",
    "Issuer": "https://your-api-domain",
    "Audience": "https://your-frontend-domain"
  },
  "Cors": {
    "AllowedOrigins": [ "https://your-frontend-domain" ]
  },
  "Seed": {
    // Initial admin account created on first startup.
    "AdminUsername": "admin",
    "AdminEmail": "admin@example.com",
    "AdminPassword": "<strong-admin-password>"
  },
  "Signup": {
    // Non-secret feature flag (lives in appsettings.json; override per-environment via
    // Signup__RequireInviteCode). When true, signup requires a valid single-use invite code —
    // mint a batch at POST /api/admin/invite-codes. See docs/auth/invite-code-system-plan.md.
    "RequireInviteCode": false
  }
}
