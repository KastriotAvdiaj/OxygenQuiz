# Base URL for all backend (ASP.NET) API calls from the frontend.
# Baked into the bundle at `vite build` time — see docs/deployment/frontend-deploy-explained.md.
VITE_API_URL=https://api.oxygenquiz.com/api

# LLM microservice URL — intentionally disabled in production (no LLM in use yet).
# Re-enable with an HTTPS URL once the LLM integration is approved.
# VITE_LLM_URL=
