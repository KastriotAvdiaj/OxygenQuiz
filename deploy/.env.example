# Copy to .env on the server and fill in real values. NEVER commit the real .env.
#   cp .env.example .env && nano .env
# Generate strong secrets:
#   Jwt__Key:        openssl rand -base64 48
#   passwords:       openssl rand -base64 24

# --- PostgreSQL (used by both the postgres container and the backend connection string) ---
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- ASP.NET runtime ---
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# --- JWT ---
Jwt__Key=CHANGE_ME_base64_at_least_32_bytes
Jwt__Issuer=https://api.oxygenquiz.com
Jwt__Audience=https://oxygenquiz.com

# --- Allowed hosts / CORS (exact origins, no wildcards) ---
AllowedHosts=api.oxygenquiz.com
Cors__AllowedOrigins__0=https://oxygenquiz.com
Cors__AllowedOrigins__1=https://www.oxygenquiz.com

# --- Invite-only signup gate (see docs/invite-code-system.md) ---
# true  = signup requires a valid, unused invite code (for the gated test).
# false = open public signup. Mint codes as admin via POST /api/admin/invite-codes.
Signup__RequireInviteCode=true

# --- Seeded admin account (created on first boot; change the password after first login) ---
Seed__AdminUsername=admin
Seed__AdminEmail=admin@oxygenquiz.com
Seed__AdminPassword=CHANGE_ME_strong_admin_password

# --- Production config gate ---
# Leave false for the first boot; set true once the domain + cookies verify, to make
# launch-blocking misconfig fatal instead of a warning. (See Program.cs / deployment.md.)
Security__EnforceProductionConfig=false
